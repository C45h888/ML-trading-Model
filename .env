# Brain Agent - Environment Configuration
# Copy this file to .env and fill in your API keys

# ===========================================
# Hyperliquid Configuration
# ===========================================
# Get your Hyperliquid API keys from https://app.hyperliquid.xyz/
# For mainnet trading, use the address and private key
HYPERLIQUID_ADDRESS=""
HYPERLIQUID_PRIVATE_KEY=""

# Testnet (optional - for paper trading)
HYPERLIQUID_TESTNET_ADDRESS=""
HYPERLIQUID_TESTNET_PRIVATE_KEY=""

# ===========================================
# MCP Server Configuration
# ===========================================
# Redis connection for MCP pub/sub
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="18188888"
REDIS_DB="0"

# MCP Server URL (optional - if using external MCP)
MCP_SERVER_URL=""

# ===========================================
# Trading Configuration
# ===========================================
# Default trading pair (e.g., BTC, ETH, SOL)
DEFAULT_SYMBOL="BTC"

# Default timeframe (1m, 5m, 15m, 1h, 4h, 1d)
DEFAULT_TIMEFRAME="1m"

# Initial capital for backtesting (in USD)
INITIAL_CAPITAL="100000"

# ===========================================
# Execution Mode
# ===========================================
# Options: backtest, paper, live
EXECUTION_MODE="paper"

# ===========================================
# PostgreSQL Configuration (self-hosted)
# ===========================================
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="trader"
POSTGRES_PASSWORD="trader_pass"
POSTGRES_DB="trading"

# ===========================================
# Logging
# ===========================================
LOG_LEVEL="INFO"

